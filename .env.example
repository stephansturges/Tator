# Runtime configuration

# CLIP backbone (e.g., ViT-B/32, RN50)
# CLIP_MODEL_NAME=ViT-B/32

# Path to trained logistic regression
# LOGREG_PATH=./my_logreg_model.pkl

# SAM configuration
# SAM_MODEL_TYPE=vit_h
# SAM_CHECKPOINT_PATH=./sam_vit_h_4b8939.pth
# SAM_VARIANT=sam1
# SAM3_MODEL_ID=facebook/sam3
# SAM3_PROCESSOR_ID=facebook/sam3
# SAM3_CHECKPOINT_PATH=
# SAM3_DEVICE=

# Force device selection (cpu|cuda). Leave unset for auto-detect
# FORCE_DEVICE=

# Falcon automatic-labeling
# FALCON_PERCEPTION_MODEL_ID=tiiuae/Falcon-Perception
# FALCON_PERCEPTION_DEVICE=cuda:0
# FALCON_PERCEPTION_LOCAL_ONLY=1

# Qwen
# QWEN_MODEL_NAME=Qwen/Qwen3-VL-4B-Instruct
# QWEN_DEVICE=auto
# QWEN_MAX_NEW_TOKENS=768

# CORS (comma-separated origins or "*")
# CORS_ALLOW_ORIGINS=*

# Enable Prometheus /metrics endpoint and middleware timings
# ENABLE_METRICS=false
