# macOS Apple Silicon inference runtime.
# Load with: tools/run_macos_backend.sh

TATOR_INFERENCE_DEVICE=auto
TATOR_ALLOW_MPS=1
# Let PyTorch route unsupported MPS ops to CPU. SAM3 currently needs this on macOS.
PYTORCH_ENABLE_MPS_FALLBACK=1

# CLIP classifier assets.
CLIP_MODEL_NAME=ViT-B/32
LOGREG_PATH=./my_logreg_model.pkl
LABELMAP_PATH=./my_label_list.pkl

# SAM1 interactive annotation path.
SAM_MODEL_TYPE=vit_h
SAM_CHECKPOINT_PATH=./sam_vit_h_4b8939.pth
SAM_VARIANT=sam1

# Optional SAM3 text/similarity path. Keep auto so MPS is used on Apple Silicon when available.
SAM3_MODEL_ID=facebook/sam3
SAM3_PROCESSOR_ID=facebook/sam3
SAM3_CHECKPOINT_PATH=
SAM3_DEVICE=auto

# Detector inference. Override either one to cpu if a model package lacks MPS support.
YOLO_INFER_DEVICE=auto
RFDETR_INFER_DEVICE=auto

# Secondary captioning path.
QWEN_MODEL_NAME=Qwen/Qwen3-VL-4B-Instruct
QWEN_DEVICE=auto
QWEN_INFERENCE_PLATFORM=auto
QWEN_MLX_MODEL_NAME=mlx-community/Qwen3-VL-4B-Instruct-4bit
QWEN_MLX_DEFAULT_QUANTIZATION=4bit
QWEN_MAX_NEW_TOKENS=768
